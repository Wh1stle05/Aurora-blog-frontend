{
  "name": "blog-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-seo-files.js && vite build && node scripts/prepare-vercel-static-config.mjs",
    "lint": "eslint .",
    "test": "vitest --passWithNoTests",
    "test:seo": "vitest run src/utils/api.test.js src/utils/assets.test.js src/hooks/usePrerenderReady.test.jsx src/pages/Home/Home.test.jsx src/pages/Blog/Blog.test.jsx src/utils/seo.test.js scripts/fetch-routes.test.js scripts/generate-seo-files.test.js scripts/verify-prerender-output.test.js scripts/prepare-vercel-static-config.test.js src/pages/BlogDetail/imageTransform.test.js src/pages/Home/uptime.test.js --configLoader native",
    "verify:prerender": "node scripts/verify-prerender-output.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "classnames": "^2.5.1",
    "framer-motion": "^12.35.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-helmet-async": "^3.0.0",
    "react-icons": "^5.5.0",
    "react-image-crop": "^11.0.10",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.5",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.1.0",
    "@prerenderer/renderer-puppeteer": "^1.2.4",
    "@prerenderer/rollup-plugin": "^0.3.12",
    "jsdom": "^25.0.0",
    "puppeteer": "^22.15.0",
    "vitest": "^3.0.0",
    "vite": "^7.1.7"
  }
}
